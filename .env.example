# Variables de entorno para Campus Duomo LMS
# Copia este archivo a .env y configura tus valores

# ============================================
# MODO DE AUTENTICACIÓN
# ============================================
# Opciones: 'demo' o 'moodle'
# - demo: Usa credenciales de prueba locales (recomendado para desarrollo)
# - moodle: Se conecta a Moodle via Web Services
VITE_AUTH_MODE=demo

# ============================================
# CONFIGURACIÓN MOODLE (solo si AUTH_MODE=moodle)
# ============================================

# URL base de la API de Moodle
VITE_MOODLE_API_URL=/webservice/rest/server.php

# URL para login de Moodle
VITE_MOODLE_LOGIN_URL=/login/token.php

# URL para subida de archivos
VITE_MOODLE_UPLOAD_URL=/webservice/upload.php

# Servicio de Moodle Mobile App
VITE_MOODLE_SERVICE=moodle_mobile_app

# Token de desarrollo (opcional, solo para pruebas)
# VITE_MOODLE_TOKEN=tu_token_aqui

# URL base del sitio Moodle (sin barra final)
VITE_MOODLE_BASE_URL=https://tumoodle.com
